<?xml version="1.0"?>
<Container version="2">
  <Name>nextchat</Name>
  <Repository>ChatGPTNextWeb/NextChat</Repository>
  <Registry>https://hub.docker.com/r/ddarek/NextChat//Dockerfile/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://hub.docker.com/r/ddarek/NextChat/</Support>
  <Project/>
  <Overview>Light and Fast AI Assistant,with Claude, DeepSeek, GPT4 & Gemini Pro support.</Overview>
  <Category/>
  <WebUI/>
  <TemplateURL/>
  <Icon>/plugins/dynamix.docker.manager/images/question.png</Icon>
